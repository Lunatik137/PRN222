@model List<Dispute>
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Dispute Management";
    var username = Context.Session.GetString("Username") ?? "Admin";
}

<div class="admin-page-wrapper">
    <div class="dashboard-shell">
        <partial name="~/Views/Admin/_AdminSidebar.cshtml" />

        <main class="dashboard-content">

            <!-- HEADER -->
            <header class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <h1 class="h3 mb-1">Dispute Management</h1>
                    <p class="text-muted mb-0">
                        Manage customer disputes. Signed in as <strong>@username</strong>
                    </p>
                </div>

                <a href="/Admin/Dashboard" class="btn btn-secondary">
                    ← Dashboard
                </a>
            </header>

            <!-- TABLE -->
            <section class="card border-0 shadow-sm">
                <div class="card-body">

                    <div class="table-responsive">
                        <table class="table table-hover align-middle">

                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Order</th>
                                    <th>User</th>
                                    <th>Description</th>
                                    <th>Status</th>
                                    <th class="text-end">Action</th>
                                </tr>
                            </thead>

                            <tbody>

                                @if (!Model.Any())
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">
                                            No disputes found
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var d in Model)
                                    {
                                        var statusClass = d.status switch
                                        {
                                            "PENDING" => "bg-warning text-dark",
                                            "IN_PROGRESS" => "bg-info",
                                            "RESOLVED" => "bg-success",
                                            "REJECTED" => "bg-danger",
                                            _ => "bg-secondary"
                                        };

                                        <tr>
                                            <td><b>#@d.id</b></td>

                                            <td>Order #@d.orderId</td>

                                            <td>@d.raisedByNavigation?.username</td>

                                            <td style="max-width:250px;">
                                                @d.description
                                            </td>

                                            <td>
                                                <span class="badge @statusClass">
                                                    @d.status
                                                </span>
                                            </td>

                                            <td class="text-end">
                                                <a href="/AdminDispute/Details/@d.id"
                                                   class="btn btn-sm btn-outline-primary">
                                                    View
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }

                            </tbody>

                        </table>
                    </div>

                </div>
            </section>

        </main>
    </div>
</div>