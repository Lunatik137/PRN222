@model PRN222_Group3.Models.EmailRequest
@{
    ViewData["Title"] = "Gửi email cảnh báo / thông báo hệ thống";
    var recipients = ViewBag.Recipients as List<PRN222_Group3.Models.User> ?? new List<PRN222_Group3.Models.User>();
    var recipientCount = ViewBag.RecipientCount is int c ? c : recipients.Count;

    string RoleLabel(string r) => r switch
    {
        "All" => "Tất cả người dùng có email",
        "Buyer" => "Người mua (Buyer)",
        "Seller" => "Người bán (Seller)",
        "SuperAdmin" => "SuperAdmin",
        "Moderator" => "Moderator",
        "Monitor" => "Monitor (giám sát)",
        "Support" => "Support",
        "Ops" => "Ops",
        _ => r
    };
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-envelope-fill"></i> @ViewData["Title"]</h4>
                </div>
                <div class="card-body">
                    @if (TempData["Message"] != null)
                    {
                        <div class="alert @(TempData["MessageType"]?.ToString() == "error" ? "alert-danger" : "alert-success") alert-dismissible fade show">
                            @TempData["Message"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="Send" method="post" id="emailForm">
                        @Html.AntiForgeryToken()

                        <div class="mb-4">
                            <label class="form-label fw-bold">
                                <i class="bi bi-people-fill"></i> Nhóm người nhận
                                <span class="text-danger">*</span>
                            </label>
                            <select asp-for="ToRole" class="form-select" required>
                                <option value="">-- Chọn nhóm --</option>
                                @foreach (var role in ViewBag.Roles as List<string>)
                                {
                                    <option value="@role">@RoleLabel(role)</option>
                                }
                            </select>
                            <div class="form-text">Bấm "Xem danh sách người nhận" để xem trước theo kiểu MVC.</div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model?.ToRole))
                        {
                            <div class="alert alert-info mb-4">
                                <strong><i class="bi bi-info-circle"></i> Người nhận:</strong>
                                @recipientCount user(s) thuộc nhóm <strong>@RoleLabel(Model.ToRole!)</strong>
                            </div>
                        }

                        @if (recipients.Any())
                        {
                            <div class="table-responsive mb-4">
                                <table class="table table-bordered table-hover">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Username</th>
                                            <th>Email</th>
                                            <th>Role</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var user in recipients)
                                        {
                                            <tr>
                                                <td>@user.Username</td>
                                                <td>@user.Email</td>
                                                <td><span class="badge bg-secondary">@user.Role</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }

                        <div class="mb-4">
                            <label asp-for="Subject" class="form-label fw-bold">
                                <i class="bi bi-tag-fill"></i> Tiêu đề email
                                <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Subject"
                                   class="form-control"
                                   placeholder="Nhập tiêu đề email"
                                   maxlength="200"
                                   required />
                            <div class="form-text" id="subjectCounter">0/200 ký tự</div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Body" class="form-label fw-bold">
                                <i class="bi bi-file-text-fill"></i> Nội dung email
                                <span class="text-danger">*</span>
                            </label>
                            <textarea asp-for="Body"
                                      class="form-control"
                                      rows="10"
                                      placeholder="Nhập nội dung cảnh báo hoặc thông báo hệ thống."
                                      required></textarea>
                            <div class="form-text">
                                Có thể dùng HTML đơn giản: &lt;b&gt;bold&lt;/b&gt;, &lt;br&gt;...
                            </div>
                        </div>

                        <div class="mb-4">
                            <button type="button" class="btn btn-outline-secondary btn-sm" id="previewToggle">
                                <i class="bi bi-eye"></i> Xem trước nội dung email
                            </button>
                        </div>

                        <div id="emailPreview" class="card mb-4 d-none">
                            <div class="card-header bg-light">
                                <strong>Preview</strong>
                            </div>
                            <div class="card-body" id="previewContent"></div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="@Url.Action("UserDashboard", "UserDashboard")" class="btn btn-secondary">
                                <i class="bi bi-x-circle"></i> Quay lại
                            </a>
                            <button type="submit" name="actionType" value="Preview" class="btn btn-outline-primary">
                                <i class="bi bi-list-check"></i> Xem danh sách người nhận
                            </button>
                            <button type="submit" name="actionType" value="Send" class="btn btn-primary"
                                    onclick="return confirm('Xác nhận gửi email cho nhóm đã chọn?');">
                                <i class="bi bi-send-fill"></i> Gửi email
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const previewToggle = document.getElementById('previewToggle');
        const preview = document.getElementById('emailPreview');
        const previewContent = document.getElementById('previewContent');
        const bodyInput = document.querySelector('textarea[name="Body"]');
        const subjectInput = document.querySelector('input[name="Subject"]');
        const subjectCounter = document.getElementById('subjectCounter');

        previewToggle.addEventListener('click', function() {
            if (preview.classList.contains('d-none')) {
                previewContent.innerHTML = bodyInput.value || '<em>Chưa có nội dung để preview</em>';
                preview.classList.remove('d-none');
                this.innerHTML = '<i class="bi bi-eye-slash"></i> Ẩn preview';
            } else {
                preview.classList.add('d-none');
                this.innerHTML = '<i class="bi bi-eye"></i> Xem trước nội dung email';
            }
        });

        function updateCounter() {
            subjectCounter.textContent = `${subjectInput.value.length}/200 ký tự`;
        }
        subjectInput.addEventListener('input', updateCounter);
        updateCounter();
    </script>
}
