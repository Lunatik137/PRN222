@model PRN222_Group3.Models.EmailRequest
@{
    ViewData["Title"] = "Send Email to Users";
    string RoleLabel(string r) => r switch
    {
        "All" => "Tất cả người dùng có email (All)",
        "SuperAdmin" => "SuperAdmin",
        "Moderator" => "Moderator",
        "Support" => "Support",
        "Ops" => "Ops",
        _ => r
    };
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-envelope-fill"></i> Send Email to Users</h4>
                </div>
                <div class="card-body">
                    <!-- Notification -->
                    @if (TempData["Message"] != null)
                    {
                        <div class="alert @(TempData["MessageType"]?.ToString() == "error" ? "alert-danger" : "alert-success") alert-dismissible fade show">
                            @TempData["Message"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="Send" method="post" id="emailForm">
                        @Html.AntiForgeryToken()

                        <!-- Recipient Role Selection -->
                        <div class="mb-4">
                            <label class="form-label fw-bold">
                                <i class="bi bi-people-fill"></i> Send To
                                <span class="text-danger">*</span>
                            </label>
                            <select asp-for="ToRole" class="form-select" id="roleSelect" required>
                                <option value="">-- Select Role --</option>
                                @foreach (var role in ViewBag.Roles as List<string>)
                                {
                                    <option value="@role">@RoleLabel(role)</option>
                                }
                            </select>
                            <div class="form-text">Select which users will receive this email</div>
                        </div>

                        <!-- Recipient Preview -->
                        <div id="recipientPreview" class="alert alert-info d-none mb-4">
                            <strong><i class="bi bi-info-circle"></i> Recipients:</strong>
                            <span id="recipientCount">0</span> user(s) will receive this email
                            <button type="button" class="btn btn-sm btn-outline-primary ms-2" id="viewRecipientsBtn">
                                <i class="bi bi-eye"></i> View Details
                            </button>
                        </div>

                        <!-- Subject Field -->
                        <div class="mb-4">
                            <label asp-for="Subject" class="form-label fw-bold">
                                <i class="bi bi-tag-fill"></i> Email Subject
                                <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Subject" 
                                   class="form-control" 
                                   placeholder="Enter email subject"
                                   maxlength="200"
                                   required />
                            <div class="form-text">Max 200 characters</div>
                        </div>

                        <!-- Body/Content Field -->
                        <div class="mb-4">
                            <label asp-for="Body" class="form-label fw-bold">
                                <i class="bi bi-file-text-fill"></i> Email Content
                                <span class="text-danger">*</span>
                            </label>
                            <textarea asp-for="Body" 
                                      class="form-control" 
                                      rows="10"
                                      placeholder="Enter your email message here. You can use HTML formatting."
                                      required></textarea>
                            <div class="form-text">
                                <i class="bi bi-lightbulb"></i> Tip: You can use HTML tags for formatting (e.g., &lt;b&gt;bold&lt;/b&gt;, &lt;br&gt;)
                            </div>
                        </div>

                        <!-- HTML Preview Toggle -->
                        <div class="mb-4">
                            <button type="button" class="btn btn-outline-secondary btn-sm" id="previewToggle">
                                <i class="bi bi-eye"></i> Preview Email
                            </button>
                        </div>

                        <!-- Preview Panel -->
                        <div id="emailPreview" class="card mb-4 d-none">
                            <div class="card-header bg-light">
                                <strong>Email Preview</strong>
                            </div>
                            <div class="card-body" id="previewContent">
                                <!-- Preview content will be inserted here -->
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="@Url.Action("UserDashboard", "UserDashboard")" class="btn btn-secondary">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-primary" id="sendBtn">
                                <i class="bi bi-send-fill"></i> Send Email
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Tips Card -->
            <div class="card shadow mt-4">
                <div class="card-header bg-info text-white">
                    <h6 class="mb-0"><i class="bi bi-info-circle-fill"></i> Email Tips</h6>
                </div>
                <div class="card-body">
                    <ul class="mb-0">
                        <li><strong>All:</strong> Sends to all users in the system</li>
                        <li><strong>Role-based:</strong> Sends only to users with the selected role</li>
                        <li><strong>HTML Support:</strong> Use HTML tags for rich formatting</li>
                        <li><strong>Test First:</strong> Consider sending to yourself first to verify formatting</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recipient Details Modal -->
<div class="modal fade" id="recipientModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-people"></i> Recipient List</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Username</th>
                                <th>Email</th>
                                <th>Role</th>
                            </tr>
                        </thead>
                        <tbody id="recipientTableBody">
                            <!-- Will be populated by JavaScript -->
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentRecipients = [];

        // Role selection change handler
        document.getElementById('roleSelect').addEventListener('change', function() {
            const role = this.value;
            if (role) {
                fetchRecipients(role);
            } else {
                document.getElementById('recipientPreview').classList.add('d-none');
            }
        });

        // Fetch recipients by role
        function fetchRecipients(role) {
            fetch(`/Email/GetRecipients?role=${encodeURIComponent(role)}`)
                .then(response => response.json())
                .then(data => {
                    currentRecipients = data.users;
                    document.getElementById('recipientCount').textContent = data.count;
                    document.getElementById('recipientPreview').classList.remove('d-none');
                })
                .catch(error => {
                    console.error('Error fetching recipients:', error);
                });
        }

        // View recipients button
        document.getElementById('viewRecipientsBtn').addEventListener('click', function() {
            const tbody = document.getElementById('recipientTableBody');
            tbody.innerHTML = '';
            
            currentRecipients.forEach(user => {
                const row = `<tr>
                    <td>${user.username}</td>
                    <td>${user.email}</td>
                    <td><span class="badge bg-secondary">${user.role}</span></td>
                </tr>`;
                tbody.innerHTML += row;
            });

            const modal = new bootstrap.Modal(document.getElementById('recipientModal'));
            modal.show();
        });

        // Preview toggle
        document.getElementById('previewToggle').addEventListener('click', function() {
            const preview = document.getElementById('emailPreview');
            const body = document.querySelector('textarea[name="Body"]').value;
            
            if (preview.classList.contains('d-none')) {
                document.getElementById('previewContent').innerHTML = body || '<em>No content to preview</em>';
                preview.classList.remove('d-none');
                this.innerHTML = '<i class="bi bi-eye-slash"></i> Hide Preview';
            } else {
                preview.classList.add('d-none');
                this.innerHTML = '<i class="bi bi-eye"></i> Preview Email';
            }
        });

        // Form submission confirmation
        document.getElementById('emailForm').addEventListener('submit', function(e) {
            const role = document.getElementById('roleSelect').value;
            const count = document.getElementById('recipientCount').textContent;
            
            if (role && count > 0) {
                const confirmed = confirm(`Are you sure you want to send this email to ${count} user(s)?`);
                if (!confirmed) {
                    e.preventDefault();
                }
            }
        });

        // Character counter for subject
        const subjectInput = document.querySelector('input[name="Subject"]');
        if (subjectInput) {
            const counterDiv = document.createElement('div');
            counterDiv.className = 'form-text text-end';
            counterDiv.id = 'subjectCounter';
            subjectInput.parentElement.appendChild(counterDiv);

            subjectInput.addEventListener('input', function() {
                const remaining = 200 - this.value.length;
                counterDiv.textContent = `${this.value.length}/200 characters`;
                counterDiv.className = remaining < 20 ? 'form-text text-end text-danger' : 'form-text text-end';
            });
        }
    </script>
}
