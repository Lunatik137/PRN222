@model IEnumerable<PRN222_Group3.Models.Review>

@{
    ViewData["Title"] = "Product Reviews";
}

@{
    ViewData["Title"] = "All Reviews";
    
    // Get filter values from ViewData for easy use in the form
    int? currentRating = ViewData["CurrentRating"] as int?;
    string currentProduct = ViewData["CurrentProduct"] as string;
    string currentSeller = ViewData["CurrentSeller"] as string;
    string currentReviewer = ViewData["CurrentReviewer"] as string;
    
    // Get pagination values from ViewBag
    int pageNumber = ViewBag.PageNumber;
    bool hasPreviousPage = ViewBag.HasPreviousPage;
    bool hasNextPage = ViewBag.HasNextPage;
    int totalPages = ViewBag.TotalPages;
}

<h1>@ViewData["Title"]</h1>
<hr />

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="card-title">Filter</h5>
        <form asp-action="Index" method="get" class="mb-4">
        <div class="row g-3">
            <div class="col-sm-6 col-md-2">
                <label for="rating" class="form-label">Rating</label>
                <select name="rating" id="rating" class="form-select">
                    <option value="">All Ratings</option>
                    <option value="1">1 Star</option>
                    <option value="2">2 Stars</option>
                    <option value="3">3 Stars</option>
                    <option value="4">4 Stars</option>
                    <option value="5">5 Stars</option>
                </select>
            </div>
            <div class="col-sm-6 col-md-3">
                <label for="productTitle" class="form-label">Product Title</label>
                <input type="text" name="productTitle" id="productTitle" value="@currentProduct" class="form-control" />
            </div>
            <div class="col-sm-6 col-md-3">
                <label for="sellerUsername" class="form-label">Seller</label>
                <input type="text" name="sellerUsername" id="sellerUsername" value="@currentSeller" class="form-control" />
            </div>
            <div class="col-sm-6 col-md-2">
                <label for="reviewerUsername" class="form-label">Reviewer</label>
                <input type="text" name="reviewerUsername" id="reviewerUsername" value="@currentReviewer" class="form-control" />
            </div>
            <div class="col-sm-12 col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary me-2">Filter</button>
                <a asp-action="Index" class="btn btn-secondary">Clear</a>
            </div>
            </div>
        </form>
    </div>
</div>

<table class="table table-bordered table-striped">
    <thead class="thead-dark">
        <tr>
            <th>ID</th>
            <th>Product</th>
            <th>Rating</th>
            <th>Comment</th>
            <th>Reviewer</th>
            <th>Seller</th>
            <th>Created At</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>
                        <a asp-controller="Product" asp-action="Product" asp-route-search="@item.Product?.Title">
                            @(item.Product?.Title ?? "N/A")
                        </a>
                    </td>
                    <td>
                        @{
                            var ratingValue = (int?)(item?.Rating) ?? 0;
                        }
                        <span class="ms-1">(@ratingValue)</span>
                    </td>
                    <td>@item.Comment</td>
                    <td>@(item.Reviewer.Username ?? "N/A")</td>         
                    <td>@(item.Product?.Seller?.Username ?? "N/A")</td> 
                    <td>@(item.CreatedAt.HasValue? item.CreatedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "N/A")</td>
                    <td>
                        <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal"
                            data-bs-target="#updateRatingModal" data-review-id="@item.Id" data-review-rating="@item.Rating"
                            data-review-comment="@item.Comment">
                            Edit
                        </button>
                        <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal"
                            data-bs-target="#deleteConfirmModal" data-review-id="@item.Id">
                            Delete
                        </button>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center">No reviews found.</td>
            </tr>

        }
    </tbody>
</table>

@if (ViewBag.TotalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            @{
                var prevDisabled = !ViewBag.HasPreviousPage ? "disabled" : "";
                var nextDisabled = !ViewBag.HasNextPage ? "disabled" : "";
            }

            <li class="page-item @prevDisabled">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="@(ViewBag.PageNumber - 1)"
                    asp-route-rating="@ViewData["CurrentRating"]" asp-route-productTitle="@ViewData["CurrentProduct"]"
                    asp-route-sellerUsername="@ViewData["CurrentSeller"]"
                    asp-route-reviewerUsername="@ViewData["CurrentReviewer"]">
                    Previous
                </a>
            </li>

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.PageNumber ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@i"
                        asp-route-rating="@ViewData["CurrentRating"]" asp-route-productTitle="@ViewData["CurrentProduct"]"
                        asp-route-sellerUsername="@ViewData["CurrentSeller"]"
                        asp-route-reviewerUsername="@ViewData["CurrentReviewer"]">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @nextDisabled">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="@(ViewBag.PageNumber + 1)"
                    asp-route-rating="@ViewData["CurrentRating"]" asp-route-productTitle="@ViewData["CurrentProduct"]"
                    asp-route-sellerUsername="@ViewData["CurrentSeller"]"
                    asp-route-reviewerUsername="@ViewData["CurrentReviewer"]">
                    Next
                </a>
            </li>
        </ul>
    </nav>
}

<!-- Update Rating Modal -->
<div class="modal fade" id="updateRatingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Update Review</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Update" asp-controller="Rating" method="post">
                <div class="modal-body">
                    <input type="hidden" name="Id" id="reviewId" />

                    <div class="mb-3">
                        <label for="Rating" class="form-label">Rating</label>
                        <select name="Rating" class="form-select" id="reviewRating" required>
                            <option value="1">1 Star</option>
                            <option value="2">2 Stars</option>
                            <option value="3">3 Stars</option>
                            <option value="4">4 Stars</option>
                            <option value="5">5 Stars</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="Comment" class="form-label">Comment</label>
                        <textarea name="Comment" class="form-control" id="reviewComment" rows="3" required></textarea>
                    </div>

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Update Review</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // Handle modal opening to populate form
    document.querySelectorAll('[data-bs-target="#updateRatingModal"]').forEach(button => {
        button.addEventListener('click', function () {
            document.getElementById('reviewId').value = this.getAttribute('data-review-id');
            document.getElementById('reviewRating').value = this.getAttribute('data-review-rating');
            document.getElementById('reviewComment').value = this.getAttribute('data-review-comment');
        });
    });

    // Handle delete confirmation modal
    document.querySelectorAll('[data-bs-target="#deleteConfirmModal"]').forEach(button => {
        button.addEventListener('click', function () {
            const reviewId = this.getAttribute('data-review-id');
            document.getElementById('deleteReviewId').value = reviewId;
        });
    });
</script>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Delete" asp-controller="Rating" method="post">
                <div class="modal-body">
                    <p>Are you sure you want to delete this review? This action cannot be undone.</p>
                    <input type="hidden" name="reviewId" id="deleteReviewId" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>