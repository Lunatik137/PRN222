@model PRN222_Group3.Views.ViewModel.ReturnRequestAdminDetailsViewModel
@{
    ViewData["Title"] = "Chi tiết yêu cầu hoàn trả";
}

<div class="container-fluid pt-4 px-4">
    @if (TempData["Message"] != null)
    {
        var type = TempData["MessageType"]?.ToString() == "success" ? "success" : "danger";
        <div class="alert alert-@type alert-dismissible fade show" role="alert">
            @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0">@ViewData["Title"] #@Model.ReturnRequestId</h4>
        <a class="btn btn-outline-secondary" asp-action="Index">← Danh sách</a>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header">Yêu cầu hoàn trả</div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Trạng thái</dt>
                        <dd class="col-sm-8"><strong>@(Model.ReturnStatus ?? "—")</strong></dd>
                        <dt class="col-sm-4">Ngày gửi</dt>
                        <dd class="col-sm-8">@(Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")</dd>
                        <dt class="col-sm-4">Lý do</dt>
                        <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Reason) ? "—" : Model.Reason)</dd>
                    </dl>
                </div>
            </div>

            @if (Model.ImageFileNames.Count > 0)
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header">Ảnh đính kèm</div>
                    <div class="card-body d-flex flex-wrap gap-2">
                        @foreach (var file in Model.ImageFileNames)
                        {
                            <a href="~/uploads/@file" target="_blank" rel="noopener">
                                <img src="~/uploads/@file" alt="@file" class="img-thumbnail" style="max-width:160px;max-height:160px;" />
                            </a>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header">Đơn hàng & người mua</div>
                <div class="card-body">
                    <dl class="row mb-0 small">
                        <dt class="col-sm-5">Mã đơn</dt>
                        <dd class="col-sm-7">@(Model.OrderId?.ToString() ?? "—")</dd>
                        <dt class="col-sm-5">Trạng thái đơn</dt>
                        <dd class="col-sm-7">@(Model.OrderStatus ?? "—")</dd>
                        <dt class="col-sm-5">Ngày đặt</dt>
                        <dd class="col-sm-7">@(Model.OrderDate?.ToString("dd/MM/yyyy HH:mm") ?? "—")</dd>
                        <dt class="col-sm-5">Tổng tiền</dt>
                        <dd class="col-sm-7">@Model.OrderTotal?.ToString("N0") VND</dd>
                        <dt class="col-sm-5">Người mua</dt>
                        <dd class="col-sm-7">@(Model.BuyerUsername ?? "—")</dd>
                        <dt class="col-sm-5">Email</dt>
                        <dd class="col-sm-7">@(Model.BuyerEmail ?? "—")</dd>
                    </dl>
                </div>
            </div>

            @if (Model.CanProcess)
            {
                <div class="card shadow-sm border-primary">
                    <div class="card-header bg-light">Thao tác (Admin)</div>
                    <div class="card-body">
                        <form asp-action="Approve" method="post" class="mb-2" onsubmit="return confirm('Duyệt yêu cầu hoàn trả này?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.ReturnRequestId" />
                            <button type="submit" class="btn btn-success w-100">Duyệt hoàn trả</button>
                        </form>
                        <form asp-action="Reject" method="post" onsubmit="return confirm('Từ chối yêu cầu hoàn trả này?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.ReturnRequestId" />
                            <button type="submit" class="btn btn-outline-danger w-100">Từ chối</button>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info mb-0">Yêu cầu đã được xử lý hoặc không còn ở trạng thái chờ duyệt.</div>
            }
        </div>
    </div>
</div>
