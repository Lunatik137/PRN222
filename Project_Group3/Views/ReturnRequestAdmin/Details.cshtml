@model Project_Group3.ViewModel.ReturnRequestAdminDetailsViewModel
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Details of the refund request";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var username = Context.Session.GetString("Username") ?? "Admin";
}

<div class="admin-page-wrapper">
    <div class="dashboard-shell">
        <partial name="~/Views/Admin/_AdminSidebar.cshtml" />

        <main class="dashboard-content">
            @if (TempData["Message"] is not null)
            {
                <div class="alert @(TempData["MessageType"]?.ToString() == "error" ? "alert-danger" : "alert-success") alert-dismissible fade show">
                    @TempData["Message"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <header class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <h1 class="h3 mb-1">@ViewData["Title"] #@Model.ReturnRequestId</h1>
                    <p class="text-muted mb-0">View and process refund requests. Signed in as <strong>@username</strong></p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary">Back to the list</a>
            </header>

            <div class="row g-3">
                <div class="col-lg-8">
                    <div class="card">
                        <div class="card-header">Content of the request</div>
                        <div class="card-body">
                            <dl class="row mb-0">
                                <dt class="col-sm-4">Return status</dt>
                                <dd class="col-sm-8"><strong>@Model.ReturnStatus</strong></dd>
                                <dt class="col-sm-4">Creation date</dt>
                                <dd class="col-sm-8">@Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</dd>
                                <dt class="col-sm-4">Reason</dt>
                                <dd class="col-sm-8">@Model.Reason</dd>
                            </dl>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="card mb-3">
                        <div class="card-header">Order</div>
                        <div class="card-body">
                            <dl class="row mb-0 small">
                                <dt class="col-sm-5">OrderId</dt>
                                <dd class="col-sm-7">@Model.OrderId</dd>
                                <dt class="col-sm-5">OrderStatus</dt>
                                <dd class="col-sm-7">@Model.OrderStatus</dd>
                                <dt class="col-sm-5">OrderDate</dt>
                                <dd class="col-sm-7">@Model.OrderDate?.ToString("dd/MM/yyyy HH:mm")</dd>
                                <dt class="col-sm-5">Total</dt>
                                <dd class="col-sm-7">@Model.OrderTotal?.ToString("N0")</dd>
                                <dt class="col-sm-5">Buyer</dt>
                                <dd class="col-sm-7">@Model.BuyerUsername</dd>
                                <dt class="col-sm-5">Email</dt>
                                <dd class="col-sm-7">@Model.BuyerEmail</dd>
                            </dl>
                        </div>
                    </div>

                    @if (Model.CanProcess)
                    {
                        <div class="card">
                            <div class="card-header">Action</div>
                            <div class="card-body">
                                <form asp-action="Approve" method="post" class="mb-2" onsubmit="return confirm('Approve this request?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.ReturnRequestId" />
                                    <button type="submit" class="btn btn-success w-100">Approve</button>
                                </form>
                                <form asp-action="Reject" method="post" onsubmit="return confirm('Reject this request?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.ReturnRequestId" />
                                    <button type="submit" class="btn btn-outline-danger w-100">Reject</button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </main>
    </div>
</div>