@model Project_Group3.ViewModel.ReturnRequestAdminIndexPageViewModel
@{
    ViewData["Title"] = "Xét duyệt yêu cầu hoàn trả";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-0">
    <div class="card mb-3">
        <div class="card-body">
            <h4 class="mb-3">@ViewData["Title"]</h4>
            <form method="get" class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Trạng thái</label>
                    <select name="status" class="form-select">
                        <option value="">-- Tất cả --</option>
                        <option value="Pending" selected="@(string.Equals(Model.Status, "Pending", StringComparison.OrdinalIgnoreCase))">Pending</option>
                        <option value="Completed" selected="@(string.Equals(Model.Status, "Completed", StringComparison.OrdinalIgnoreCase))">Completed</option>
                        <option value="Rejected" selected="@(string.Equals(Model.Status, "Rejected", StringComparison.OrdinalIgnoreCase))">Rejected</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Page size</label>
                    <select name="pageSize" class="form-select">
                        @foreach (var s in new[] { 10, 20, 50 })
                        {
                            <option value="@s" selected="@(Model.PageSize == s)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Lọc</button>
                </div>
            </form>
        </div>
    </div>

    @if (TempData["Message"] is not null)
    {
        <div class="alert @(TempData["MessageType"]?.ToString() == "error" ? "alert-danger" : "alert-success") alert-dismissible fade show">
            @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>RequestId</th>
                        <th>OrderId</th>
                        <th>Buyer</th>
                        <th>Email</th>
                        <th>Order Status</th>
                        <th>Return Status</th>
                        <th>Created</th>
                        <th>Reason</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Items.Any())
                    {
                        <tr><td colspan="9" class="text-center py-3 text-muted">Không có dữ liệu</td></tr>
                    }
                    else
                    {
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.ReturnRequestId</td>
                                <td>@item.OrderId</td>
                                <td>@item.BuyerUsername</td>
                                <td>@item.BuyerEmail</td>
                                <td>@item.OrderStatus</td>
                                <td><span class="badge bg-secondary">@item.ReturnStatus</span></td>
                                <td>@item.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@item.ReasonPreview</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.ReturnRequestId" class="btn btn-sm btn-outline-primary">Chi tiết</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination">
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-status="@Model.Status" asp-route-page="@i" asp-route-pageSize="@Model.PageSize">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>
