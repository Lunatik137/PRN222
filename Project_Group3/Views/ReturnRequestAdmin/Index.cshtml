@model PRN222_Group3.Views.ViewModel.ReturnRequestAdminIndexPageViewModel
@{
    ViewData["Title"] = "Xét duyệt hoàn trả đơn hàng";
    var r = Model.Result;
}

<div class="container-fluid pt-4 px-4">
    <h4 class="mb-4">@ViewData["Title"]</h4>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Trạng thái yêu cầu</label>
                    <select name="status" class="form-select" id="returnStatusFilter">
                        @{
                            var statusOpts = new (string Val, string Label)[]
                            {
                                ("", "— Tất cả —"),
                                ("Pending", "Chờ xử lý (Pending)"),
                                ("Completed", "Đã duyệt (Completed)"),
                                ("Rejected", "Đã từ chối (Rejected)")
                            };
                        }
                        @foreach (var o in statusOpts)
                        {
                            if (Model.StatusFilter == o.Val)
                            {
                                <option value="@o.Val" selected>@o.Label</option>
                            }
                            else
                            {
                                <option value="@o.Val">@o.Label</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Số dòng / trang</label>
                    <select name="pageSize" class="form-select" id="returnPageSize">
                        @foreach (var ps in new[] { 10, 25, 50 })
                        {
                            if (r.PageSize == ps)
                            {
                                <option value="@ps" selected>@ps</option>
                            }
                            else
                            {
                                <option value="@ps">@ps</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Lọc</button>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive bg-white rounded shadow-sm">
        <table class="table table-hover table-bordered mb-0">
            <thead class="table-light">
                <tr>
                    <th>ID yêu cầu</th>
                    <th>Đơn hàng</th>
                    <th>Người mua</th>
                    <th>Trạng thái đơn</th>
                    <th>Trạng thái hoàn trả</th>
                    <th>Ngày gửi</th>
                    <th>Lý do (rút gọn)</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (!r.Items.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">Không có yêu cầu nào.</td>
                    </tr>
                }
                else
                {
                    foreach (var row in r.Items)
                    {
                        <tr>
                            <td>@row.ReturnRequestId</td>
                            <td>@(row.OrderId?.ToString() ?? "—")</td>
                            <td>@(row.BuyerUsername ?? "—")</td>
                            <td>@(row.OrderStatus ?? "—")</td>
                            <td><span class="badge bg-secondary">@(row.ReturnStatus ?? "—")</span></td>
                            <td>@(row.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")</td>
                            <td>@(row.ReasonPreview ?? "—")</td>
                            <td>
                                <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@row.ReturnRequestId">Chi tiết</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (r.TotalPages > 1)
    {
        <nav class="mt-3" aria-label="Phân trang">
            <ul class="pagination">
                <li class="page-item @(r.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-status="@Model.StatusFilter" asp-route-page="@(r.PageNumber - 1)" asp-route-pageSize="@r.PageSize">Trước</a>
                </li>
                @for (var i = 1; i <= r.TotalPages; i++)
                {
                    <li class="page-item @(i == r.PageNumber ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-status="@Model.StatusFilter" asp-route-page="@i" asp-route-pageSize="@r.PageSize">@i</a>
                    </li>
                }
                <li class="page-item @(r.HasNextPage ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-status="@Model.StatusFilter" asp-route-page="@(r.PageNumber + 1)" asp-route-pageSize="@r.PageSize">Sau</a>
                </li>
            </ul>
        </nav>
    }
</div>
