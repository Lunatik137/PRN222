﻿@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Home Page";
    var username = Context.Session.GetString("Username");
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>

    @if (TempData["LoginMessage"] is string loginMessage)
    {
        <div class="alert alert-success">@loginMessage</div>
    }

    @if (string.IsNullOrEmpty(username))
    {
        <p>You are not logged in yet.</p>
        <a asp-controller="Account" asp-action="Login" class="btn btn-primary">Login</a>
    }
    else
    {
        <p>You are logged in with account <strong>@username</strong>.</p>
    }

    <p class="mt-3">Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>