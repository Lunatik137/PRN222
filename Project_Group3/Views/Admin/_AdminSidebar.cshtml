@using Microsoft.AspNetCore.Http
@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    string IsActive(string action) => string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty;
    var role = Context.Session.GetString("Role") ?? string.Empty;
    var isSuperAdmin = string.Equals(role, "superadmin", StringComparison.OrdinalIgnoreCase);
}

<aside class="dashboard-sidebar">
    <div class="brand">Marketplace Admin</div>
    <nav class="menu list-unstyled">
        <a asp-controller="Admin" asp-action="Dashboard" class="menu-link @IsActive("Dashboard")">Dashboard</a>
        <a asp-controller="Admin" asp-action="UserManagement" class="menu-link @IsActive("UserManagement")">User Management</a>
        @if (isSuperAdmin)
        {
            <a asp-controller="Admin" asp-action="ProductModeration" class="menu-link @IsActive("ProductModeration")">Product Moderation</a>
        }
        <a asp-controller="Admin" asp-action="OrderManagement" class="menu-link @IsActive("OrderManagement")">Order Management</a>
        <a asp-controller="Admin" asp-action="ReviewsFeedback" class="menu-link @IsActive("ReviewsFeedback")">Reviews & Feedback</a>
        <a asp-controller="Admin" asp-action="ComplaintsDisputes" class="menu-link @IsActive("ComplaintsDisputes")">Complaints / Disputes</a>
        <a asp-controller="Admin" asp-action="Analytics" class="menu-link @IsActive("Analytics")">Analytics</a>
        <a asp-controller="Admin" asp-action="SystemSettings" class="menu-link @IsActive("SystemSettings")">System Settings</a>
    </nav>
</aside>