@using Microsoft.AspNetCore.Http
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    string IsActive(string controller, string? action = null)
    {
        var isControllerMatch = string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase);
        var isActionMatch = action is null || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
        return isControllerMatch && isActionMatch ? "active" : string.Empty;
    }

    var role = Context.Session.GetString("Role") ?? string.Empty;
}

<aside class="dashboard-sidebar">
    <nav class="menu list-unstyled">
        @if (AdminPermissions.CanAccessDashboard(role))
        {
            <a asp-controller="AdminDashboard" asp-action="Dashboard" class="menu-link @IsActive("AdminDashboard", "Dashboard")">Dashboard</a>
        }

        @if (AdminPermissions.CanAccessUserManagement(role))
        {
            <a asp-controller="Admin" asp-action="UserManagement" class="menu-link @IsActive("Admin", "UserManagement")">User Management</a>
        }

        @if (AdminPermissions.CanAccessProductModeration(role))
        {
            <a asp-controller="Admin" asp-action="ProductModeration" class="menu-link @IsActive("Admin", "ProductModeration")">Product Moderation</a>
        }

        @if (AdminPermissions.CanAccessOrders(role))
        {
            <a asp-controller="AdminOrder" asp-action="Index" class="menu-link @IsActive("AdminOrder")">Order Management</a>
        }

        @if (AdminPermissions.CanAccessRefunds(role))
        {
            <a asp-controller="ReturnRequestAdmin" asp-action="Index" class="menu-link @IsActive("ReturnRequestAdmin")">Return Request Approval</a>
        }

        @if (AdminPermissions.CanAccessEmailSystem(role))
        {
            <a asp-controller="Email" asp-action="Send" class="menu-link @IsActive("Email")">System Email Notification</a>
        }

        @if (AdminPermissions.CanAccessReviewsFeedback(role))
        {
            <a asp-controller="AdminReviewFeedback" asp-action="ReviewsFeedback" class="menu-link @IsActive("AdminReviewFeedback", "ReviewsFeedback")">Reviews & Feedback</a>
        }

        @if (AdminPermissions.CanAccessDisputes(role))
        {
            <a asp-controller="AdminDispute" asp-action="IndexDispute" class="menu-link @IsActive("AdminDispute")">Complaints / Disputes</a>
        }

        @if (AdminPermissions.CanAccessAnalytics(role))
        {
            <a asp-controller="AdminAnalytics" asp-action="Analytics" class="menu-link @IsActive("AdminAnalytics", "Analytics")">Analytics</a>
        }

        @if (AdminPermissions.CanUseSystemSettings(role))
        {
            <a asp-controller="Admin" asp-action="SystemSettings" class="menu-link @IsActive("Admin", "SystemSettings")">System Settings</a>
        }
    </nav>
</aside>
