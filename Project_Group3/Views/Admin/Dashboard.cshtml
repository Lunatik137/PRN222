@model Project_Group3.ViewModel.DashboardViewModel
@using Microsoft.AspNetCore.Http
@using System.Globalization
@{
    ViewData["Title"] = "Admin Dashboard";
    var username = Context.Session.GetString("Username") ?? "Admin";
    var role = Context.Session.GetString("Role") ?? string.Empty;
    var isSuperAdmin = string.Equals(role, "superadmin", StringComparison.OrdinalIgnoreCase);

    var ordersMax = Math.Max(1, Model.OrdersTrendSeries.DefaultIfEmpty(0).Max());
    var usersMax = Math.Max(1, Model.NewUsersSeries.DefaultIfEmpty(0).Max());

    var usersDeltaClass = Model.NewUsersDeltaPercent >= 0 ? "delta-up" : "delta-down";
    var ordersDeltaClass = Model.OrdersDeltaPercent >= 0 ? "delta-up" : "delta-down";
    var usersDeltaSign = Model.NewUsersDeltaPercent >= 0 ? "+" : string.Empty;
    var ordersDeltaSign = Model.OrdersDeltaPercent >= 0 ? "+" : string.Empty;

    var donutPalette = new[] { "#5b44d6", "#8d7bff", "#b4a7ff", "#ddd6ff" };
    var donutStops = new List<string>();
    decimal donutCursor = 0m;
    for (var i = 0; i < Model.CategoryDistribution.Count; i++)
    {
        var item = Model.CategoryDistribution[i];
        var start = donutCursor;
        donutCursor += item.Percentage;
        donutStops.Add($"{donutPalette[i % donutPalette.Length]} {start.ToString("0.#", CultureInfo.InvariantCulture)}% {donutCursor.ToString("0.#", CultureInfo.InvariantCulture)}%");
    }
    if (donutStops.Count == 0)
    {
        donutStops.Add("#ddd6ff 0% 100%");
    }
}
<div id="notificationBox"
     style="position: fixed; top:20px; right:20px; z-index:9999;"></div>
<div class="admin-page-wrapper">
    <div class="dashboard-shell">
        <partial name="~/Views/Admin/_AdminSidebar.cshtml" />

        <main class="dashboard-content hub-dashboard">
            <header class="hub-header mb-4">
                <div>
                    <h1 class="hub-title mb-1">Admin Dashboard</h1>
                    <p class="hub-subtitle mb-0">Overview of live system statistics</p>
                </div>
                <div class="hub-header-actions">
                    <div class="hub-user small text-muted">Signed in as <strong>@username</strong></div>
                </div>
            </header>

            <section class="row g-3 mb-4">
                <div class="col-12 col-md-6 col-xl-4">
                    <article class="card hub-kpi-card h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="hub-kpi-label">Total Users</span>
                                <span class="hub-icon" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 19a6 6 0 0 0-12 0m15 0h3m-3 0a6 6 0 0 0-3-5.2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm9 1a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" />
                                    </svg>
                                </span>
                            </div>
                            <h2 class="hub-kpi-value mb-0">@Model.TotalUsers.ToString("N0")</h2>
                            <small class="hub-kpi-note">New today: @Model.NewUsersToday.ToString("N0")</small>
                            <small class="hub-kpi-note @usersDeltaClass">vs yesterday (@Model.NewUsersYesterday.ToString("N0")): @usersDeltaSign@Model.NewUsersDeltaPercent.ToString("0.#")%</small>
                        </div>
                    </article>
                </div>

                <div class="col-12 col-md-6 col-xl-4">
                    <article class="card hub-kpi-card h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="hub-kpi-label">Total Products</span>
                                <span class="hub-icon" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="m3 7 9-4 9 4m-18 0 9 4m-9-4v10l9 4m9-14-9 4m9-4v10l-9 4m0-10v10" />
                                    </svg>
                                </span>
                            </div>
                            <h2 class="hub-kpi-value mb-0">@Model.TotalProducts.ToString("N0")</h2>
                            <small class="hub-kpi-note">Total revenue: @Model.TotalRevenue.ToString("N2")</small>
                        </div>
                    </article>
                </div>

                <div class="col-12 col-md-6 col-xl-4">
                    <article class="card hub-kpi-card h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="hub-kpi-label">Total Orders</span>
                                <span class="hub-icon" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 6h2l1.2 8.2A2 2 0 0 0 8.2 16H17a2 2 0 0 0 2-1.6L21 8H7m2 12a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Zm10 0a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z" />
                                    </svg>
                                </span>
                            </div>
                            <h2 class="hub-kpi-value mb-0">@Model.TotalOrders.ToString("N0")</h2>
                            <small class="hub-kpi-note">Orders today: @Model.OrdersToday.ToString("N0")</small>
                            <small class="hub-kpi-note @ordersDeltaClass">vs yesterday (@Model.OrdersYesterday.ToString("N0")): @ordersDeltaSign@Model.OrdersDeltaPercent.ToString("0.#")%</small>
                        </div>
                    </article>
                </div>
            </section>

            <section class="row g-3 mb-3">
                <div class="col-12 col-xl-7">
                    <article class="card hub-panel h-100">
                        <div class="card-body">
                            <div class="hub-panel-head">
                                <h3 class="h5 mb-0">Orders Trend (Last 7 Days)</h3>
                            </div>
                            <div class="hub-trend-list mt-3">
                                @for (var i = 0; i < Model.OrdersTrendSeries.Count; i++)
                                {
                                    var value = Model.OrdersTrendSeries[i];
                                    var width = (int)Math.Round((value * 100d) / ordersMax);
                                    <div class="hub-trend-item">
                                        <span class="trend-label">@Model.OrdersTrendLabels[i]</span>
                                        <div class="trend-bar-wrap">
                                            <span class="trend-bar" style="width:@Math.Max(width, value > 0 ? 8 : 0)%"></span>
                                        </div>
                                        <strong class="trend-value">@value</strong>
                                    </div>
                                }
                            </div>
                        </div>
                    </article>
                </div>

                <div class="col-12 col-md-6 col-xl-5">
                    <article class="card hub-panel h-100">
                        <div class="card-body">
                            <div class="hub-panel-head">
                                <h3 class="h5 mb-0">New Users (Last 6 Months)</h3>
                            </div>
                            <div class="hub-bar-chart mt-3" aria-hidden="true">
                                @for (var i = 0; i < Model.NewUsersSeries.Count; i++)
                                {
                                    var value = Model.NewUsersSeries[i];
                                    var height = (int)Math.Round((value * 100d) / usersMax);
                                    <div class="hub-bar-item" title="@Model.NewUsersLabels[i]: @value">
                                        <small class="bar-value">@value</small>
                                        <span style="height:@Math.Max(height, value > 0 ? 8 : 0)%"></span>
                                    </div>
                                }
                            </div>
                            <div class="hub-axis-labels">
                                @for (var i = 0; i < Model.NewUsersLabels.Count; i++)
                                {
                                    <small>@Model.NewUsersLabels[i]</small>
                                }
                            </div>
                        </div>
                    </article>
                </div>

                <div class="col-12 col-md-6 col-xl-4">
                    <article class="card hub-panel h-100">
                        <div class="card-body">
                            <div class="hub-panel-head">
                                <h3 class="h5 mb-0">Category Distribution</h3>
                            </div>
                            <div class="hub-donut-wrap">
                                <div class="hub-donut" aria-hidden="true" style="background: conic-gradient(@string.Join(", ", donutStops));"></div>
                                <ul class="hub-legend list-unstyled mb-0">
                                    @for (var i = 0; i < Model.CategoryDistribution.Count; i++)
                                    {
                                        var item = Model.CategoryDistribution[i];
                                        <li><i class="dot" style="background:@donutPalette[i % donutPalette.Length]"></i> @item.Name @item.Percentage.ToString("0.#")% (@item.Count)</li>
                                    }
                                    @if (Model.CategoryDistribution.Count == 0)
                                    {
                                        <li>No product category data yet.</li>
                                    }
                                </ul>
                            </div>
                        </div>
                    </article>
                </div>

                <div class="col-12 col-md-6 col-xl-4">
                    <article class="card hub-panel h-100">
                        <div class="card-body">
                            <div class="hub-panel-head">
                                <h3 class="h5 mb-0">Recent Activities</h3>
                            </div>
                            <ul class="hub-list list-unstyled mb-0 mt-2">
                                @foreach (var item in Model.RecentActivities)
                                {
                                    <li>
                                        <span class="bullet"></span>
                                        @item.Title
                                        <small>@item.TimeLabel</small>
                                    </li>
                                }
                                @if (!Model.RecentActivities.Any())
                                {
                                    <li>
                                        <span class="bullet"></span>
                                        No recent activity
                                        <small>-</small>
                                    </li>
                                }
                            </ul>
                        </div>
                    </article>
                </div>

                <div class="col-12 col-xl-4">
                    <article class="card hub-panel h-100">
                        <div class="card-body">
                            <div class="hub-panel-head">
                                <h3 class="h5 mb-0">Admin Alerts</h3>
                            </div>
                            <div class="table-responsive mt-2">
                                <table class="table table-sm align-middle mb-0 hub-alert-table">
                                    <thead>
                                        <tr>
                                            <th>Alert</th>
                                            <th class="text-end">Level</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var alert in Model.Alerts)
                                        {
                                            var levelClass = string.Equals(alert.Level, "High", StringComparison.OrdinalIgnoreCase)
                                                ? "pill pill-danger"
                                                : string.Equals(alert.Level, "Warning", StringComparison.OrdinalIgnoreCase)
                                                    ? "pill pill-warn"
                                                    : "pill pill-info";

                                            <tr>
                                                <td>@alert.Message</td>
                                                <td class="text-end"><span class="@levelClass">@alert.Level</span></td>
                                            </tr>
                                        }
                                        @if (!Model.Alerts.Any())
                                        {
                                            <tr>
                                                <td>No alerts</td>
                                                <td class="text-end"><span class="pill pill-info">Info</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </article>
                </div>

                <div class="col-12 col-xl-4">
                    <article class="card hub-panel h-100">
                        <div class="card-body">
                            <div class="hub-panel-head">
                                <h3 class="h5 mb-0">Quick Actions</h3>
                                <span class="badge hub-badge">Ready</span>
                            </div>
                            <div class="d-grid gap-2 mt-3">
                                <a asp-controller="Admin" asp-action="UserManagement" class="btn btn-hub">Approve new users</a>
                                @if (isSuperAdmin)
                                {
                                    <a asp-controller="Admin" asp-action="ProductModeration" class="btn btn-hub-outline">Review reported products</a>
                                }
                                <a asp-controller="AdminDispute" asp-action="IndexDispute" class="btn btn-hub-outline">View complaints</a>
                                <a asp-controller="ReturnRequestAdmin" asp-action="Index" class="btn btn-hub-outline">Approve return requests</a>
                                <a asp-controller="Email" asp-action="Send" class="btn btn-hub-outline">Send system warning email</a>
                                <a asp-controller="Admin" asp-action="SystemSettings" class="btn btn-hub-outline">Manage system settings</a>
                            </div>
                        </div>
                    </article>
                </div>
            </section>
        </main>
    </div>
</div>

<style>
    .hub-dashboard {
        background: #f7f7fc;
    }

    .hub-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
    }

    .hub-title {
        font-size: 1.7rem;
        font-weight: 700;
        color: #1f1b3d;
    }

    .hub-subtitle {
        color: #6b6b82;
    }

    .hub-header-actions {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 8px;
    }

    .btn-outline-hub {
        border-color: #c8c2ff;
        color: #5b44d6;
        background: #fff;
    }

    .btn-outline-hub:hover {
        border-color: #5b44d6;
        color: #4a33c5;
        background: #f5f2ff;
    }

    .hub-kpi-card {
        border: 1px solid #ebe7ff;
        border-radius: 14px;
        box-shadow: 0 8px 24px rgba(74, 51, 197, 0.08);
        transition: transform .18s ease, box-shadow .18s ease;
        background: #fff;
    }

    .hub-kpi-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 30px rgba(74, 51, 197, 0.12);
    }

    .hub-kpi-label {
        color: #6f6a8b;
        font-size: .86rem;
        font-weight: 600;
    }

    .hub-kpi-value {
        color: #1f1b3d;
        font-size: 2.2rem;
        font-weight: 800;
        line-height: 1.1;
    }

    .hub-kpi-note {
        color: #8d88a8;
        font-size: .76rem;
        font-weight: 500;
        display: block;
        margin-top: 4px;
    }

    .delta-up {
        color: #1f8f4d;
    }

    .delta-down {
        color: #c62828;
    }

    .hub-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        background: #f1edff;
        color: #5b44d6;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .hub-icon svg {
        width: 19px;
        height: 19px;
    }

    .hub-panel {
        border: 1px solid #ece8ff;
        border-radius: 14px;
        box-shadow: 0 6px 18px rgba(43, 34, 94, 0.06);
        background: #fff;
    }

    .hub-panel-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
    }

    .hub-badge {
        background: #f2efff;
        color: #5b44d6;
        border: 1px solid #ddd4ff;
        font-weight: 600;
    }

    .hub-trend-list {
        display: grid;
        gap: 10px;
    }

    .hub-trend-item {
        display: grid;
        grid-template-columns: 70px 1fr 40px;
        align-items: center;
        gap: 10px;
    }

    .trend-label {
        font-size: .8rem;
        color: #6f6a8b;
    }

    .trend-bar-wrap {
        height: 10px;
        background: #f1edff;
        border-radius: 999px;
        overflow: hidden;
    }

    .trend-bar {
        display: block;
        height: 100%;
        background: linear-gradient(90deg, #7b61ff 0%, #5b44d6 100%);
        border-radius: 999px;
    }

    .trend-value {
        text-align: right;
        font-size: .82rem;
        color: #4f4a6c;
    }

    .hub-bar-chart {
        height: 170px;
        display: flex;
        align-items: flex-end;
        gap: 10px;
        padding: 12px;
        border-radius: 10px;
        background: #faf9ff;
    }

    .hub-bar-item {
        flex: 1;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        gap: 6px;
    }

    .hub-bar-item span {
        display: block;
        width: 100%;
        flex: 0 0 auto;
        border-radius: 8px 8px 0 0;
        background: linear-gradient(180deg, #7b61ff 0%, #5b44d6 100%);
    }

    .bar-value {
        color: #5f5a7d;
        font-size: .72rem;
        text-align: center;
        font-weight: 600;
    }

    .hub-axis-labels {
        margin-top: 8px;
        display: flex;
        justify-content: space-between;
        gap: 6px;
    }

    .hub-axis-labels small {
        color: #8d88a8;
        font-size: .7rem;
    }

    .hub-donut-wrap {
        margin-top: 10px;
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 14px;
        align-items: center;
    }

    .hub-donut {
        width: 116px;
        height: 116px;
        border-radius: 50%;
        position: relative;
    }

    .hub-donut::after {
        content: '';
        position: absolute;
        inset: 24px;
        background: #fff;
        border-radius: 50%;
    }

    .hub-legend li {
        margin-bottom: 6px;
        color: #5f5a7d;
        font-size: .86rem;
    }

    .dot {
        width: 9px;
        height: 9px;
        display: inline-block;
        border-radius: 50%;
        margin-right: 6px;
    }

    .hub-list li {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 10px 0;
        border-bottom: 1px solid #f0ecff;
        color: #4f4a6c;
        font-size: .9rem;
    }

    .hub-list li:last-child {
        border-bottom: none;
    }

    .hub-list small {
        color: #8d88a8;
    }

    .bullet {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #5b44d6;
        display: inline-block;
        margin-right: 8px;
        flex: 0 0 auto;
    }

    .hub-alert-table th {
        color: #7c7698;
        font-size: .78rem;
        font-weight: 600;
    }

    .hub-alert-table td {
        color: #4f4a6c;
    }

    .pill {
        display: inline-block;
        font-size: .72rem;
        padding: 2px 8px;
        border-radius: 999px;
        font-weight: 600;
    }

    .pill-warn {
        background: #fff4d9;
        color: #a76400;
    }

    .pill-danger {
        background: #ffe2e2;
        color: #c62828;
    }

    .pill-info {
        background: #e4f2ff;
        color: #0d6efd;
    }

    .btn-hub {
        background: #5b44d6;
        border: 1px solid #5b44d6;
        color: #fff;
    }

    .btn-hub:hover {
        background: #4a33c5;
        border-color: #4a33c5;
        color: #fff;
    }

    .btn-hub-outline {
        background: #f5f2ff;
        border: 1px solid #d4ccff;
        color: #4a33c5;
    }

    .btn-hub-outline:hover {
        background: #ebe5ff;
        border-color: #c3b7ff;
        color: #3f2ab2;
    }

    @@media (max-width: 991.98px) {
        .hub-header {
            flex-direction: column;
        }

        .hub-header-actions {
            align-items: flex-start;
        }
    }

    @@media (max-width: 575.98px) {
        .hub-kpi-value {
            font-size: 1.9rem;
        }

        .hub-donut-wrap {
            grid-template-columns: 1fr;
            justify-items: center;
        }

        .hub-legend {
            width: 100%;
        }

        .hub-trend-item {
            grid-template-columns: 1fr;
            gap: 6px;
        }

        .trend-value {
            text-align: left;
        }
    }
</style>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
<script>
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/notificationHub")
        .build();

    connection.on("OrderUpdated", function (message) {

        const box = document.getElementById("notificationBox");

        const noti = document.createElement("div");
        noti.className = "alert alert-info shadow";
        noti.innerText = message;

        box.appendChild(noti);

        setTimeout(() => {
            noti.remove();
        }, 4000);
    });

    connection.start();
</script>
