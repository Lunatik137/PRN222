@using Project_Group3.Models
@{
    var username = Context.Session.GetString("Username") ?? "Admin";
    var currentTab = ViewBag.CurrentTab as string ?? "reviews";
}

<div class="admin-page-wrapper">
    <div class="dashboard-shell">
        <partial name="_AdminSidebar" />

        <main class="dashboard-content">
            <div class="container-fluid py-4">
                <h2>Reviews & Feedback</h2>
                <p>Monitor products and sellers for any violations.</p>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success mt-2">@TempData["SuccessMessage"]</div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger mt-2">@TempData["ErrorMessage"]</div>
                }

                <ul class="nav nav-tabs mt-4">
                    <li class="nav-item">
                        <a class="nav-link @(currentTab == "reviews" ? "active" : "")" href="/Admin/ReviewsFeedback?tab=reviews">All Reviews</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentTab == "sellers" ? "active" : "")" href="/Admin/ReviewsFeedback?tab=sellers">Seller Feedbacks</a>
                    </li>
                </ul>

                <div class="tab-content border border-top-0 p-3 bg-white">
                    @if (currentTab == "reviews")
                    {
                        var reviews = ViewBag.ReviewItems as IEnumerable<Review>;
                        
                        <form method="get" class="row g-3 mb-4">
                            <input type="hidden" name="tab" value="reviews" />
                            <div class="col-md-4">
                                <input type="text" name="keyword" class="form-control" placeholder="Search product name..." value="@ViewBag.Keyword" />
                            </div>
                            <div class="col-md-3">
                                <select name="ratingFilter" class="form-select">
                                    <option value="">All Ratings</option>
                                    <option value="5" selected="@(ViewBag.RatingFilter == 5 ? "selected" : null)">5 Stars</option>
                                    <option value="4" selected="@(ViewBag.RatingFilter == 4 ? "selected" : null)">4 Stars</option>
                                    <option value="3" selected="@(ViewBag.RatingFilter == 3 ? "selected" : null)">3 Stars</option>
                                    <option value="2" selected="@(ViewBag.RatingFilter == 2 ? "selected" : null)">2 Stars</option>
                                    <option value="1" selected="@(ViewBag.RatingFilter == 1 ? "selected" : null)">1 Star</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <button type="submit" class="btn btn-primary">Filter</button>
                                <a href="/Admin/ReviewsFeedback?tab=reviews" class="btn btn-secondary">Clear</a>
                            </div>
                        </form>

                        <div class="table-responsive">
                            <table class="table table-striped table-hover align-middle">
                                <thead class="table-dark">
                                    <tr>
                                        <th>ID</th>
                                        <th>Product</th>
                                        <th>Reviewer</th>
                                        <th>Rating</th>
                                        <th>Comment</th>
                                        <th>Date</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if(reviews != null) {
                                        foreach (var review in reviews)
                                        {
                                            <tr>
                                                <td>@review.id</td>
                                                <td>@(review.product?.title ?? "N/A")</td>
                                                <td>@(review.reviewer?.username ?? review.reviewer?.email ?? "N/A")</td>
                                                <td>
                                                    @for (int i = 0; i < review.rating; i++) { <i class="text-warning">★</i> }
                                                </td>
                                                <td>@review.comment</td>
                                                <td>@review.createdAt?.ToString("dd/MM/yyyy")</td>
                                                <td>
                                                    <form asp-controller="Admin" asp-action="DeleteReview" method="post" onsubmit="return confirm('Are you sure you want to delete this review?');">
                                                        <input type="hidden" name="id" value="@review.id" />
                                                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else if (currentTab == "sellers")
                    {
                        var feedbacks = ViewBag.SellerItems as IEnumerable<Feedback>;
                        
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Seller ID</th>
                                        <th>Username</th>
                                        <th>Total Reviews</th>
                                        <th>Avg Rating</th>
                                        <th>Positive Rate</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if(feedbacks != null) {
                                        foreach (var fb in feedbacks)
                                        {
                                            var isRisky = fb.positiveRate < 80 || fb.averageRating < 3;
                                            <tr class="@(isRisky ? "table-danger" : "")">
                                                <td>@fb.sellerId</td>
                                                <td>@(fb.seller?.username ?? "N/A")</td>
                                                <td>@fb.totalReviews</td>
                                                <td>@fb.averageRating / 5.0</td>
                                                <td>
                                                    <div class="progress" style="height: 20px;">
                                                        <div class="progress-bar @(isRisky ? "bg-danger" : "bg-success")" 
                                                             style="width: @(fb.positiveRate)%;">
                                                            @fb.positiveRate%
                                                        </div>
                                                    </div>
                                                </td>
                                                <td>
                                                    @if(isRisky) { <span class="badge bg-danger">Risky</span> }
                                                    else { <span class="badge bg-success">Good</span> }
                                                </td>
                                                <td>
                                                    <a href="#" class="btn btn-sm btn-outline-danger">Lock</a>
                                                    <a href="#" class="btn btn-sm btn-outline-warning">Warn</a>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    <!-- Pagination -->
                    @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
                    {
                        <nav class="mt-3">
                            <ul class="pagination">
                                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                                {
                                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                        <a class="page-link" href="/Admin/ReviewsFeedback?tab=@currentTab&page=@i&keyword=@ViewBag.Keyword&ratingFilter=@ViewBag.RatingFilter">@i</a>
                                    </li>
                                }
                            </ul>
                        </nav>
                    }
                </div>
            </div>
        </main>
    </div>
</div>
