@using Project_Group3.Models
@using Microsoft.AspNetCore.Http
@{
    var username = Context.Session.GetString("Username") ?? "Admin";
    var currentTab = ViewBag.CurrentTab as string ?? "reviews";
    var canProcessReviews = ViewBag.CanProcessReviews is bool canProcess && canProcess;
    var canDeleteReviews = ViewBag.CanDeleteReviews is bool canDelete && canDelete;
    var reviews = ViewBag.ReviewItems as IEnumerable<Review> ?? new List<Review>();
    var feedbacks = ViewBag.SellerItems as IEnumerable<Feedback> ?? new List<Feedback>();
    var currentPage = ViewBag.CurrentPage is int page ? page : 1;
    var totalPages = ViewBag.TotalPages is int total ? total : 0;
}

<div class="admin-page-wrapper">
    <div class="dashboard-shell">
        <partial name="~/Views/Admin/_AdminSidebar.cshtml" />

        <main class="dashboard-content">
            <div class="container-fluid py-4">
                <h2>Reviews & Feedback</h2>
                <p>Monitor products and sellers for any violations. Signed in as <strong>@username</strong>.</p>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success">@TempData["SuccessMessage"]@TempData["ActionStatus"]</div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                }

                <ul class="nav nav-tabs mt-4">
                    <li class="nav-item">
                        <a class="nav-link @(currentTab == "reviews" ? "active" : "")" href="/AdminReviewFeedback/ReviewsFeedback?tab=reviews">All Reviews</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentTab == "sellers" ? "active" : "")" href="/AdminReviewFeedback/ReviewsFeedback?tab=sellers">Seller Feedbacks</a>
                    </li>
                </ul>

                <div class="tab-content border border-top-0 p-3 bg-white">
                    @if (currentTab == "reviews")
                    {
                        <form method="get" class="row g-3 mb-4">
                            <input type="hidden" name="tab" value="reviews" />
                            <div class="col-md-2">
                                <input type="text" name="keyword" class="form-control" placeholder="Product..." value="@ViewBag.Keyword" />
                            </div>
                            <div class="col-md-2">
                                <input type="text" name="sellerIdSearch" class="form-control" placeholder="Seller ID" value="@ViewBag.SellerIdSearch" />
                            </div>
                            <div class="col-md-2">
                                <select name="ratingFilter" class="form-select">
                                    <option value="">All Ratings</option>
                                    <option value="5" selected="@(ViewBag.RatingFilter == 5 ? "selected" : null)">5 Stars</option>
                                    <option value="4" selected="@(ViewBag.RatingFilter == 4 ? "selected" : null)">4 Stars</option>
                                    <option value="3" selected="@(ViewBag.RatingFilter == 3 ? "selected" : null)">3 Stars</option>
                                    <option value="2" selected="@(ViewBag.RatingFilter == 2 ? "selected" : null)">2 Stars</option>
                                    <option value="1" selected="@(ViewBag.RatingFilter == 1 ? "selected" : null)">1 Star</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <select name="statusFilter" class="form-select">
                                    <option value="">All Statuses</option>
                                    <option value="Pending" selected="@(ViewBag.StatusFilter == "Pending" ? "selected" : null)">Pending</option>
                                    <option value="Approved" selected="@(ViewBag.StatusFilter == "Approved" ? "selected" : null)">Approved</option>
                                    <option value="Rejected" selected="@(ViewBag.StatusFilter == "Rejected" ? "selected" : null)">Rejected</option>
                                    <option value="Hidden" selected="@(ViewBag.StatusFilter == "Hidden" ? "selected" : null)">Hidden</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <select name="pageSize" class="form-select" onchange="this.form.submit()">
                                    <option value="6" selected="@(ViewBag.PageSize == 6 ? "selected" : null)">6 per page</option>
                                    <option value="10" selected="@(ViewBag.PageSize == 10 ? "selected" : null)">10 per page</option>
                                    <option value="20" selected="@(ViewBag.PageSize == 20 ? "selected" : null)">20 per page</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <button type="submit" class="btn btn-primary">Filter</button>
                                <a href="/AdminReviewFeedback/ReviewsFeedback?tab=reviews" class="btn btn-secondary">Clear</a>
                            </div>
                        </form>

                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead>
                                    <tr>
                                        <th>Reviewer</th>
                                        <th>Product</th>
                                        <th>Rating</th>
                                        <th>Status</th>
                                        <th>Comment</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!reviews.Any())
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center text-muted">No reviews found.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        foreach (var review in reviews)
                                        {
                                            var status = review.status ?? "Pending";
                                            <tr>
                                                <td>
                                                    <div class="fw-semibold">@(review.reviewer?.username ?? review.reviewer?.email ?? "Unknown User")</div>
                                                    <small class="text-muted">@(review.createdAt?.ToString("dd/MM/yyyy") ?? "-")</small>
                                                </td>
                                                <td>
                                                    <div class="fw-semibold">@(review.product?.title ?? "N/A")</div>
                                                    <small class="text-muted">Seller ID: @(review.product?.sellerId?.ToString() ?? "-")</small>
                                                </td>
                                                <td>@(review.rating ?? 0)/5</td>
                                                <td>@status</td>
                                                <td style="max-width: 360px; white-space: normal;">@review.comment</td>
                                                <td>
                                                    @if (!canProcessReviews)
                                                    {
                                                        <span class="text-muted">View only</span>
                                                    }
                                                    else if (status == "Pending")
                                                    {
                                                        <div class="d-flex gap-2">
                                                            <form asp-controller="AdminReviewFeedback" asp-action="UpdateReviewStatus" method="post">
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="id" value="@review.id" />
                                                                <input type="hidden" name="newStatus" value="Approved" />
                                                                <button type="submit" class="btn btn-sm btn-success">Approve</button>
                                                            </form>
                                                            <form asp-controller="AdminReviewFeedback" asp-action="UpdateReviewStatus" method="post" onsubmit="return confirm('Reject this review?')">
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="id" value="@review.id" />
                                                                <input type="hidden" name="newStatus" value="Rejected" />
                                                                <button type="submit" class="btn btn-sm btn-danger">Reject</button>
                                                            </form>
                                                        </div>
                                                    }
                                                    else if (status == "Approved" || status == "Show")
                                                    {
                                                        <div class="d-flex gap-2">
                                                            <form asp-controller="AdminReviewFeedback" asp-action="UpdateReviewStatus" method="post">
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="id" value="@review.id" />
                                                                <input type="hidden" name="newStatus" value="Hidden" />
                                                                <button type="submit" class="btn btn-sm btn-secondary">Hide</button>
                                                            </form>
                                                            @if (canDeleteReviews)
                                                            {
                                                                <form asp-controller="AdminReviewFeedback" asp-action="UpdateReviewStatus" method="post" onsubmit="return confirm('Permanently delete this review?')">
                                                                    @Html.AntiForgeryToken()
                                                                    <input type="hidden" name="id" value="@review.id" />
                                                                    <input type="hidden" name="newStatus" value="Deleted" />
                                                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                                                </form>
                                                            }
                                                        </div>
                                                    }
                                                    else if (status == "Hidden")
                                                    {
                                                        <form asp-controller="AdminReviewFeedback" asp-action="UpdateReviewStatus" method="post">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="id" value="@review.id" />
                                                            <input type="hidden" name="newStatus" value="Show" />
                                                            <button type="submit" class="btn btn-sm btn-info text-white">Show</button>
                                                        </form>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Seller ID</th>
                                        <th>Username</th>
                                        <th>Total Reviews</th>
                                        <th>Avg Rating</th>
                                        <th>Positive Rate</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!feedbacks.Any())
                                    {
                                        <tr>
                                            <td colspan="7" class="text-center text-muted">No feedback records found.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        foreach (var fb in feedbacks)
                                        {
                                            var isRisky = fb.positiveRate < 80 || fb.averageRating < 3;
                                            <tr class="@(isRisky ? "table-danger" : "")">
                                                <td>@fb.sellerId</td>
                                                <td>@(fb.seller?.username ?? "N/A")</td>
                                                <td>@fb.totalReviews</td>
                                                <td>@fb.averageRating / 5.0</td>
                                                <td>@fb.positiveRate%</td>
                                                <td>@(isRisky ? "Risky" : "Good")</td>
                                                <td>@(canProcessReviews ? "Processing role" : "View only")</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    @if (totalPages > 0)
                    {
                        <nav class="mt-4 pb-3 d-flex justify-content-between align-items-center">
                            <div class="text-muted fw-bold">Page @currentPage of @totalPages</div>
                            <ul class="pagination mb-0">
                                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" href="/AdminReviewFeedback/ReviewsFeedback?tab=@currentTab&page=@(currentPage - 1)&pageSize=@ViewBag.PageSize&keyword=@ViewBag.Keyword&sellerIdSearch=@ViewBag.SellerIdSearch&ratingFilter=@ViewBag.RatingFilter&statusFilter=@ViewBag.StatusFilter">Previous</a>
                                </li>
                                @for (int i = 1; i <= totalPages; i++)
                                {
                                    <li class="page-item @(i == currentPage ? "active" : "")">
                                        <a class="page-link" href="/AdminReviewFeedback/ReviewsFeedback?tab=@currentTab&page=@i&pageSize=@ViewBag.PageSize&keyword=@ViewBag.Keyword&sellerIdSearch=@ViewBag.SellerIdSearch&ratingFilter=@ViewBag.RatingFilter&statusFilter=@ViewBag.StatusFilter">@i</a>
                                    </li>
                                }
                                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                    <a class="page-link" href="/AdminReviewFeedback/ReviewsFeedback?tab=@currentTab&page=@(currentPage + 1)&pageSize=@ViewBag.PageSize&keyword=@ViewBag.Keyword&sellerIdSearch=@ViewBag.SellerIdSearch&ratingFilter=@ViewBag.RatingFilter&statusFilter=@ViewBag.StatusFilter">Next</a>
                                </li>
                            </ul>
                        </nav>
                    }
                </div>
            </div>
        </main>
    </div>
</div>

