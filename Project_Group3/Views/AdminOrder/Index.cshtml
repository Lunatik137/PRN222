<div class="container-fluid">
    <div class="mt-3">
        <a href="/Admin/Dashboard" class="btn btn-secondary">
            ← Back to DashBoard
        </a>
    </div>
    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold">Order Management</h3>


    </div>

    <!-- CARD -->
    <div class="card shadow-sm border-0">

        <div class="card-body p-0">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Buyer</th>
                        <th>Date</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var o in Model)
                    {
                        <tr>
                            <td><b>#@o.id</b></td>

                            <td>
                                <div>
                                    <b> @o.buyer?.username</b><br />
                                    <small class="text-muted">Buyer</small>
                                </div>
                            </td>

                            <td>
                                @o.orderDate?.ToString("dd/MM/yyyy")
                            </td>

                            <td>
                                <b>$@o.totalPrice?.ToString("N0")</b>
                            </td>

                            <td>

                                @if (o.status == "PAID")
                                {
                                    <span class="badge bg-primary">Paid</span>
                                }
                                @* else if (o.status == "SHIPPING") *@
                                @* { *@
                                @*     <span class="badge bg-info">Shipping</span> *@
                                @* } *@
                                @* else if (o.status == "DELIVERED") *@
                                @* { *@
                                @*     <span class="badge bg-success">Delivered</span> *@
                                @* } *@
                                else if (o.status == "REFUNDED")
                                {
                                    <span class="badge bg-warning text-dark">Refunded</span>
                                }
                                @* else if (o.status == "CANCELLED") *@
                                @* { *@
                                @*     <span class="badge bg-danger">Cancelled</span> *@
                                @* } *@
                                else
                                {
                                    <span class="badge bg-secondary">@o.status</span>
                                }

                            </td>

                            <td class="text-end">

                                <a class="btn btn-sm btn-outline-primary"
                                   href="/AdminOrder/Details/@o.id">
                                    View
                                </a>

                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>
    </div>

</div>