@model List<Project_Group3.Models.OrderTable>
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Order Management";
    var username = Context.Session.GetString("Username") ?? "Admin";
}

<div class="admin-page-wrapper">
    <div class="dashboard-shell">

        <!-- SIDEBAR -->
        <partial name="~/Views/Admin/_AdminSidebar.cshtml" />

        <!-- CONTENT -->
        <main class="dashboard-content">

            <!-- HEADER -->
            <header class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <h1 class="h3 mb-1">Order Management</h1>
                    <p class="text-muted mb-0">
                        Manage all orders in system. Signed in as <strong>@username</strong>
                    </p>
                </div>
            </header>

         

            <!-- CARD -->
            <section class="card border-0 shadow-sm">

                <div class="card-body">

                    <div class="table-responsive">
                        <table class="table table-hover align-middle">

                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Buyer</th>
                                    <th>Date</th>
                                    <th>Total</th>
                                    <th>Status</th>
                                    <th class="text-end">Action</th>
                                </tr>
                            </thead>

                            <tbody>

                                @if (!Model.Any())
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">
                                            No orders found.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var o in Model)
                                    {
                                        var status = (o.status ?? "").ToUpper();

                                        var badge = status switch
                                        {
                                            "PAID" => "bg-primary",
                                            "SHIPPING" => "bg-info",
                                            "DELIVERED" => "bg-success",
                                            "REFUNDED" => "bg-warning text-dark",
                                            "CANCELLED" => "bg-danger",
                                            "PENDING" => "bg-secondary",
                                            _ => "bg-secondary"
                                        };

                                        <tr>
                                            <td><b>#@o.id</b></td>

                                            <td>
                                                <div>
                                                    <b>@o.buyer?.username</b><br />
                                                    <small class="text-muted">Buyer</small>
                                                </div>
                                            </td>

                                            <td>
                                                @o.orderDate?.ToString("dd/MM/yyyy")
                                            </td>

                                            <td>
                                                <b>$@o.totalPrice?.ToString("N0")</b>
                                            </td>

                                            <td>
                                                <span class="badge @badge">@status</span>
                                            </td>

                                            <td class="text-end">
                                                <a class="btn btn-sm btn-outline-primary"
                                                   href="/AdminOrder/Details/@o.id">
                                                    View
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }

                            </tbody>

                        </table>
                    </div>

                </div>

            </section>

        </main>
    </div>
</div>