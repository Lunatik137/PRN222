<h2 class="mb-4">Order Details</h2>

<div class="card shadow-sm mb-4">
    <div class="card-body">

        <div class="row">

            <div class="col-md-6">
                <p><b>Order ID:</b> #@Model.id</p>
                <p><b>Buyer:</b> User @Model.buyerId</p>
            </div>

            <div class="col-md-6">
                <p><b>Date:</b> @Model.orderDate?.ToString("dd/MM/yyyy")</p>

                <p>
                    <b>Status:</b>

                    @if (Model.status == "Paid")
                    {
                        <span class="badge bg-warning text-dark">Paid</span>
                    }
                    else if (Model.status == "Refunded")
                    {
                        <span class="badge bg-primary">Refunded</span>
                    }
                    @* else if (Model.status == "Delivered") *@
                    @* { *@
                    @*     <span class="badge bg-success">Delivered</span> *@
                    @* } *@
                    @* else if (Model.status == "Cancelled") *@
                    @* { *@
                    @*     <span class="badge bg-danger">Cancelled</span> *@
                    @* } *@
                    else
                    {
                        <span class="badge bg-secondary">@Model.status</span>
                    }

                </p>

            </div>

        </div>

    </div>
</div>


<h3 class="mb-3">Products</h3>

<div class="card shadow-sm mb-4">
    <div class="card-body">

        <table class="table table-hover align-middle">

            <thead class="table-dark">
                <tr>
                    <th>Product Title</th>
                    <th>Quantity</th>
                    <th>Price</th>
                    <th>Subtotal</th>
                </tr>
            </thead>
            <tbody>

                @{
                    decimal total = 0;
                }

                @foreach (var item in ViewBag.Items)
                {
                    var subtotal = item.quantity * item.unitPrice;
                    total += subtotal;

                    <tr>
                        <td>@item.product?.title</td>
                        <td>@item.quantity</td>
                        <td>$@item.unitPrice</td>
                        <td>$@subtotal</td>
                    </tr>
                }

            </tbody>

        </table>

        <div class="text-end mt-3">
            <h5>Total: <b>$@total</b></h5>
        </div>
    </div>
</div>


<h3 class="mb-3">Update Status</h3>

<div class="card shadow-sm">
    <div class="card-body">

        <form method="post" asp-action="UpdateStatus">

            <input type="hidden" name="id" value="@Model.id" />

            <div class="row">

                <div class="col-md-4">

                    <select name="status" class="form-select">

                        <option value="Paid" selected="@(Model.status == "Paid")">
                            Paid
                        </option>

                        <option value="Refunded" selected="@(Model.status == "Refunded")">
                            Refunded
                        </option>

                        @* <option value="Delivered" selected="@(Model.status == "Delivered")"> *@
                        @*     Delivered *@
                        @* </option> *@

                        @* <option value="Cancelled" selected="@(Model.status == "Cancelled")"> *@
                        @*     Cancelled *@
                        @* </option> *@

                    </select>

                </div>

                <div class="col-md-2">

                    <button class="btn btn-primary">
                        Update
                    </button>

                </div>

            </div>

        </form>

    </div>
</div>
<div class="mt-3">
    <a href="/AdminOrder" class="btn btn-secondary">
        ← Back to Orders
    </a>
</div>