@model Project_Group3.Models.OrderTable
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Order Details";
    var username = Context.Session.GetString("Username") ?? "Admin";
    var role = Context.Session.GetString("Role") ?? string.Empty;
    var canProcessOrders = AdminPermissions.CanProcessOrders(role);
}

<div class="admin-page-wrapper">
    <div class="dashboard-shell">
        <partial name="~/Views/Admin/_AdminSidebar.cshtml" />

        <main class="dashboard-content">
            <header class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <h1 class="h3 mb-1">Order Details</h1>
                    <p class="text-muted mb-0">Manage order information. Signed in as <strong>@username</strong></p>
                </div>
            </header>

            <div class="mb-3">
                <a href="/AdminOrder" class="btn btn-outline-secondary btn-sm">? Back to Orders</a>
            </div>

            <section class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><b>Order ID:</b> #@Model.id</p>
                            <p><b>Buyer:</b> @Model.buyer?.username</p>
                        </div>

                        <div class="col-md-6">
                            <p><b>Date:</b> @Model.orderDate?.ToString("dd/MM/yyyy")</p>
                            <p>
                                <b>Status:</b>
                                @{
                                    var status = (Model.status ?? "").ToUpper();
                                    var badge = status switch
                                    {
                                        "PAID" => "bg-primary",
                                        "SHIPPING" => "bg-info",
                                        "DELIVERED" => "bg-success",
                                        "REFUNDED" => "bg-warning text-dark",
                                        "CANCELLED" => "bg-danger",
                                        "PENDING" => "bg-secondary",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badge">@status</span>
                            </p>
                        </div>
                    </div>
                </div>
            </section>

            <section class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h5 class="mb-3">Products</h5>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>Quantity</th>
                                    <th>Price</th>
                                    <th>Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    decimal total = 0;
                                }

                                @foreach (var item in ViewBag.Items)
                                {
                                    var subtotal = item.quantity * item.unitPrice;
                                    total += subtotal;

                                    <tr>
                                        <td><b>@item.product?.title</b></td>
                                        <td>@item.quantity</td>
                                        <td>$@item.unitPrice.ToString("N0")</td>
                                        <td>$@subtotal.ToString("N0")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="text-end mt-3">
                        <h5>Total: <b>$@total.ToString("N0")</b></h5>
                    </div>
                </div>
            </section>

            <section class="card border-0 shadow-sm">
                <div class="card-body">
                    @if (canProcessOrders)
                    {
                        <h5 class="mb-3">Update Status</h5>

                        <form method="post" asp-action="UpdateStatus">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.id" />

                            <div class="row">
                                <div class="col-md-4">
                                    <select name="status" class="form-select">
                                        <option value="PAID" selected="@(Model.status == "PAID")">Paid</option>
                                        <option value="PENDING" selected="@(Model.status == "PENDING")">Pending</option>
                                        <option value="SHIPPING" selected="@(Model.status == "SHIPPING")">Shipping</option>
                                        <option value="DELIVERED" selected="@(Model.status == "DELIVERED")">Delivered</option>
                                        <option value="REFUNDED" selected="@(Model.status == "REFUNDED")">Refunded</option>
                                        <option value="CANCELLED" selected="@(Model.status == "CANCELLED")">Cancelled</option>
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <button class="btn btn-primary">Update</button>
                                </div>
                            </div>
                        </form>
                    }
                    else
                    {
                        <h5 class="mb-3">Order Status</h5>
                        <p class="text-muted mb-0">Your role can view order details but cannot change order status.</p>
                    }
                </div>
            </section>
        </main>
    </div>
</div>
