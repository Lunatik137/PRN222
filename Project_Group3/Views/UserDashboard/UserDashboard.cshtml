@model IEnumerable<PRN222_Group3.Models.User>
@{
    ViewData["Title"] = "User Management";
    bool canWrite = User.IsInRole("SuperAdmin") || User.IsInRole("Moderator");
    bool? isApproved = ViewBag.IsApproved as bool?;
    bool? isLocked = ViewBag.IsLocked as bool?;
    // Create returnUrl properly
    string currentUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="container mt-4">
    <h2 class="mb-4 text-center fw-bold">User Management</h2>

    @if (User.IsInRole("SuperAdmin") || User.IsInRole("Moderator") || User.IsInRole("Monitor") || User.IsInRole("Support") || User.IsInRole("Ops"))
    {
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="card border-primary h-100 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title"><i class="bi bi-arrow-return-left text-primary"></i> Xét duyệt hoàn trả đơn hàng</h5>
                        <p class="card-text text-muted small mb-3">Danh sách yêu cầu hoàn trả, duyệt / từ chối (task Admin 1.4).</p>
                        <a class="btn btn-primary mt-auto" asp-controller="ReturnRequestAdmin" asp-action="Index">Mở trang hoàn trả</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card border-warning h-100 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title"><i class="bi bi-megaphone text-warning"></i> Email cảnh báo hệ thống</h5>
                        <p class="card-text text-muted small mb-3">Gửi thông báo tới toàn bộ user hoặc theo vai trò (task Admin 2.5).</p>
                        <a class="btn btn-warning mt-auto" asp-controller="Email" asp-action="Send">Mở gửi email</a>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- 2FA Security Card -->
    <div class="card shadow-sm mb-4 border-info">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0"><i class="bi bi-shield-lock"></i> Account Security</h5>
        </div>
        <div class="card-body">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h6 class="fw-bold">Two-Factor Authentication (2FA)</h6>
                    <p class="mb-0 text-muted">
                        @if (ViewBag.TwoFactorEnabled == true)
                        {
                            <span class="badge bg-success"><i class="bi bi-check-circle"></i> Enabled</span>
                            <span class="ms-2">Your account is protected with 2FA</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark"><i class="bi bi-exclamation-triangle"></i> Not Enabled</span>
                            <span class="ms-2">Add an extra layer of security to your account</span>
                        }
                    </p>
                </div>
                <div class="col-md-4 text-end">
                    @if (ViewBag.TwoFactorEnabled == true)
                    {
                        <form asp-controller="TwoFactorAuth" asp-action="Disable" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Are you sure you want to disable two-factor authentication?')">
                                <i class="bi bi-shield-x"></i> Disable 2FA
                            </button>
                        </form>
                    }
                    else
                    {
                        <a href="@Url.Action("Setup", "TwoFactorAuth")" class="btn btn-primary">
                            <i class="bi bi-shield-plus"></i> Enable 2FA
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Keyword</label>
                    <input type="text" name="keyword" class="form-control" value="@ViewBag.Keyword" placeholder="Username / Email..." />
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-semibold">Approval Status</label>
                    <select name="isApproved" class="form-select">
                        <option value="">-- All --</option>
                        <option value="true" selected="@(isApproved == true)">Approved</option>
                        <option value="false" selected="@(isApproved == false)">Pending</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-semibold">Lock Status</label>
                    <select name="isLocked" class="form-select">
                        <option value="">-- All --</option>
                        <option value="true" selected="@(isLocked == true)">Locked</option>
                        <option value="false" selected="@(isLocked == false)">Active</option>
                    </select>
                </div>

                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Filter</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Notifications -->
    @if (TempData["Message"] != null)
    {
        <div class="alert @(TempData["MessageType"]?.ToString() == "error" ? "alert-danger" : "alert-success") alert-dismissible fade show">
            @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Data Table -->
    <div class="table-responsive shadow-sm">
        <table class="table table-bordered table-hover align-middle text-center">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Approved</th>
                    <th>Locked</th>
                    <th>Lock Reason</th>
                    <th>Created At</th>
                    @if (canWrite)
                    {
                        <th>Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td>@u.Id</td>
                        <td>@u.Username</td>
                        <td>@u.Email</td>
                        <td>@u.Role</td>
                        <td>@(u.IsApproved ? "✔️" : "❌")</td>
                        <td>@(u.IsLocked ? "🔒" : "🔓")</td>
                        <td>@u.LockedReason</td>
                        <td>@u.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>

                        @if (canWrite)
                        {
                            <td>
                                @if (!u.IsApproved)
                                {
                                    <!-- ✅ Form Duyệt với popup xác nhận -->
                                    <form asp-action="Approve" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to approve user @u.Username?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@u.Id" />
                                        <input type="hidden" name="returnUrl" value="@currentUrl" />
                                        <button type="submit" class="btn btn-sm btn-success px-3">
                                            <i class="bi bi-check-circle"></i> Approve
                                        </button>
                                    </form>
                                }

                                @if (!u.IsLocked)
                                {
                                    <!-- ✅ Form Khóa -->
                                    <button type="button" class="btn btn-sm btn-warning px-3" onclick="showLockModal(@u.Id, '@u.Username', '@currentUrl')">
                                        <i class="bi bi-lock"></i> Lock
                                    </button>
                                }
                                else
                                {
                                    <!-- ✅ Form Mở khóa -->
                                    <form asp-action="Unlock" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to unlock user @u.Username?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@u.Id" />
                                        <input type="hidden" name="returnUrl" value="@currentUrl" />
                                        <button type="submit" class="btn btn-sm btn-info px-3">
                                            <i class="bi bi-unlock"></i> Unlock
                                        </button>
                                    </form>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @{
        int total = ViewBag.Total;
        int page = ViewBag.Page;
        int pageSize = ViewBag.PageSize;
        int pages = (int)Math.Ceiling(total / (double)pageSize);
    }

    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @for (int p = 1; p <= pages; p++)
            {
                <li class="page-item @(p == page ? "active" : "")">
                    <a class="page-link"
                       href="@Url.Action("UserDashboard", "UserDashboard", new { page = p, pageSize, keyword = ViewBag.Keyword, isApproved = isApproved, isLocked = isLocked })">
                        @p
                    </a>
                </li>
            }
        </ul>
    </nav>
</div>

<!-- Lock Account Modal -->
<div class="modal fade" id="lockModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Lock Account</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="lockForm" method="post" asp-action="Lock">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <p>Are you sure you want to lock account <strong id="lockUsername"></strong>?</p>
                    <input type="hidden" name="id" id="lockUserId" />
                    <input type="hidden" name="returnUrl" id="lockReturnUrl" />
                    <div class="mb-3">
                        <label class="form-label">Lock Reason <span class="text-danger">*</span></label>
                        <textarea name="reason" class="form-control" rows="3" required placeholder="Enter reason for locking the account..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning">Lock Account</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showLockModal(userId, username, returnUrl) {
            document.getElementById('lockUserId').value = userId;
            document.getElementById('lockUsername').textContent = username;
            document.getElementById('lockReturnUrl').value = returnUrl;
            var modal = new bootstrap.Modal(document.getElementById('lockModal'));
            modal.show();
        }
    </script>
}